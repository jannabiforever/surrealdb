/**
[env]
imports = ["bench/util/records-100000-fulltext.surql"]

[bench]
reason = "Full-text search for two terms combined with AND (BM25)"
run = true
rebuild = false
warmup = "2s"
sample-size = 50
measurement-time = "20s"

[test]
run = false
*/

SELECT * FROM record WHERE words @@ 'hello' AND words @@ 'world' LIMIT 1000;
