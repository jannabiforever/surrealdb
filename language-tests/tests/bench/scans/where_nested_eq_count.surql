/**
[bench]
reason = "Count records matching equality on a deeply nested object field"
run = true
rebuild = false
datasets = { unindexed = "bench/util/records-10000.surql", indexed = "bench/util/records-10000-indexed.surql" }
warmup = "2s"
sample-size = 50
measurement-time = "20s"

[test]
run = false
*/

SELECT count() FROM record WHERE geography.region.details.continent = 'Asia' GROUP ALL;
