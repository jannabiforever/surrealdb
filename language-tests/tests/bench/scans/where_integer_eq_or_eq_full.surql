/**
[bench]
reason = "Select records matching either of two integer equalities"
run = true
rebuild = false
datasets = { unindexed = "bench/util/records-100000.surql", indexed = "bench/util/records-100000-indexed.surql" }
warmup = "2s"
sample-size = 50
measurement-time = "20s"

[test]
run = false
*/

SELECT * FROM record WHERE number = 21 OR number = 22;
